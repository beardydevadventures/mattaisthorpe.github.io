---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

import Hero from "../../components/Hero.astro";
import Grid from "../../components/Grid.astro";
import PostPreview from "../../components/PostPreview.astro";
import { slugifyTag } from "../../utils/slug";

interface Props {
	tag: string;
	posts: CollectionEntry<"posts">[];
}

export async function getStaticPaths() {
	const posts = await getCollection("posts");
	const tags = Array.from(
		new Set(posts.flatMap((post) => post.data.tags ?? [])),
	);
	return tags.map((tag) => ({
		params: { tag: slugifyTag(tag) },
		props: { tag, posts },
	}));
}

const { tag, posts } = Astro.props as Props;
const taggedPosts = posts
	.filter((post) => post.data.tags?.some((t) => slugifyTag(t) === slugifyTag(tag)))
	.sort(
		(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
	);
---

<BaseLayout
	title={`${tag} Articles | Matthew Aisthorpe`}
	description={`Browse articles tagged with ${tag}.`}
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<div class="stack gap-2">
				<a class="back-link" href="/blog/">Back to Blog</a>
				<Hero
					title={tag}
					tagline={`Articles tagged with ${tag}.`}
					align="start"
				/>
			</div>
			<Grid variant="offset">
				{
					taggedPosts.map((post) => (
						<li>
							<PostPreview post={post} />
						</li>
					))
				}
			</Grid>
		</main>
	</div>
</BaseLayout>

<style>
	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
		color: inherit;
		font-family: var(--font-brand);
	}

	.back-link:hover,
	.back-link:focus {
		text-decoration-color: currentColor;
	}
</style>
