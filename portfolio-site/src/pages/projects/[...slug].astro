---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'projects'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/core-concepts/routing/#dynamic-routes
export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const formattedDate = new Date(entry.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const awardLabels = {
	winner: 'Winner',
	finalist: 'Finalist',
} as const;
const awardIcons = {
	winner: 'trophy',
	finalist: 'medal',
} as const;
const awardLabel = entry.data.awardStatus ? awardLabels[entry.data.awardStatus] : undefined;
const awardIcon = entry.data.awardStatus ? awardIcons[entry.data.awardStatus] : undefined;
const pathname = Astro.url?.pathname ?? `/projects/${entry.id}`;
const fullUrl = `https://matthewaisthorpe.com.au${pathname}`;
const image = entry.data.img;
const fullImage = image?.startsWith('http')
  ? image
  : `https://matthewaisthorpe.com.au${image}`;
const projectSchema = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	name: entry.data.title,
	description: entry.data.description,
	image: fullImage,
	url: fullUrl,
	datePublished: new Date(entry.data.publishDate).toISOString(),
	...(awardLabel ? { award: awardLabel } : {}),
	author: {
		'@type': 'Person',
		name: 'Matthew Aisthorpe',
		url: 'https://matthewaisthorpe.com.au/',
	},
	keywords: entry.data.tags,
};
---

<BaseLayout
	title={entry.data.title}
	description={entry.data.description}
	url={fullUrl}
	image={fullImage}
	type="article"
	schema={projectSchema}
>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/projects/"><Icon icon="arrow-left" /> Projects</a>
					<Hero title={entry.data.title} align="start">
						<div class="meta-row">
							<time class="publish-date" datetime={new Date(entry.data.publishDate).toISOString()}>{formattedDate}</time>
							{awardLabel && awardIcon && (
								<span class:list={['award-badge', `is-${entry.data.awardStatus}`]}>
									<Icon icon={awardIcon} size="1em" />
									{awardLabel}
								</span>
							)}
						</div>
						<div class="details">
							<div class="tags max-lg:hidden">
								{entry.data.tags.map((t: string) => <Pill>{t}</Pill>)}
							</div>
							<p class="description">{entry.data.description}</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					{entry.data.img && <img src={entry.data.img} alt={entry.data.img_alt || ''} />}
					<div class="content">
						<Content />
					</div>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.publish-date {
		font-size: var(--text-md);
		color: var(--gray-400);
		margin-top: 0.25rem;
	}

	.meta-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}

	.award-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.42rem 0.7rem;
		border: 1px solid color-mix(in srgb, currentColor, transparent 72%);
		border-radius: 999rem;
		background: var(--surface-panel-strong);
		box-shadow: var(--shadow-sm);
		font-size: var(--text-sm);
		font-weight: 700;
		line-height: 1;
		text-transform: uppercase;
	}

	.award-badge.is-winner {
		color: #f7c948;
	}

	.award-badge.is-finalist {
		color: #9dd7ff;
	}

	.tags {
		display: none;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.content {
		max-width: 65ch;
		margin-inline: auto;
		font-size: var(--text-lg);
		line-height: 1.7;
	}

	.content > :global(* + *) {
		margin-top: 1.2rem;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4),
	.content :global(h5) {
		margin: 2rem 0 1rem;
		line-height: 1.2;
		text-wrap: balance;
	}

	.content :global(h1) {
		font-size: var(--text-3xl);
	}

	.content :global(h2) {
		font-size: var(--text-2xl);
	}

	.content :global(h3) {
		font-size: var(--text-xl);
	}

	.content :global(h4) {
		font-size: var(--text-lg);
	}

	.content :global(h5) {
		font-size: var(--text-md);
	}

	.content :global(p) {
		margin: 0.9rem 0;
	}

	.content :global(hr) {
		border: none;
		border-top: 1px solid var(--gray-800);
		margin: 2rem 0;
	}

	.content :global(img) {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	.content :global(blockquote) {
		font-size: var(--text-xl);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.2;
		padding: 1rem 1.5rem;
		border-radius: 1rem;
		border: 1px solid var(--gray-800);
		background: var(--gradient-subtle);
		color: var(--gray-0);
	}

	.back-link,
	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.back-link:hover,
	.back-link:focus,
	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	.content :global(ul),
	.content :global(ol) {
		list-style: initial;
		padding-left: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin: 1rem 0;
	}

	.content :global(ol) {
		list-style-type: decimal;
	}

	.content :global(li) {
		line-height: 1.6;
	}

	@media (min-width: 50em) {
		header .wrapper {
			max-width: none;
		}

		header :global(.hero),
		header :global(.hero .title) {
			width: 100%;
		}

		header :global(.hero .title) {
			max-width: 100%;
		}

		.back-link {
			display: block;
			align-self: flex-start;
		}

		.details {
			flex-direction: row;
			gap: 2.5rem;
		}

		.content :global(blockquote) {
			font-size: var(--text-2xl);
		}

		.content :global(h1) {
			font-size: var(--text-4xl);
		}

		.content :global(h2) {
			font-size: var(--text-3xl);
		}

		.content :global(h3) {
			font-size: var(--text-2xl);
		}

		.tags {
			display: flex;
			gap: 0.5rem;
		}
	}
</style>
