---
import { getCollection } from "astro:content";

// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from "../layouts/BaseLayout.astro";

// Component Imports
import CallToAction from "../components/CallToAction.astro";
import Grid from "../components/Grid.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";
import type { iconPaths } from "../components/IconPaths";
import Pill from "../components/Pill.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import PostPreview from "../components/PostPreview.astro";

// Page section components
import ContactCTA from "../components/ContactCTA.astro";
import Skills from "../components/Skills.astro";

// Content Fetching: List four most recent blog posts
const posts = (await getCollection("posts"))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Content Fetching: List four most recent work projects
const projects = (await getCollection("projects"))
	.filter((p) => p.data.featured) // Only keep featured projects
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()) // Sort by date
	.slice(0, 4); // Show only 4

const recognitions: { title: string; icon: keyof typeof iconPaths }[] = [
	{
		title: "XRCC 2026 Finalist",
		icon: "trophy",
	},
	{
		title: "Meta Horizon Start Program, Start Partner",
		icon: "planet",
	},
	{
		title: "Meta Connect 2025 - Invited Start Partner",
		icon: "seal-check",
	},
	{
		title: "Multi-Platform App Releases (Meta Quest, Android, iOS, Steam)",
		icon: "rocket-launch",
	},
	{
		title: "GovHack Winner (2019, 2022) & Runner-Up (2021)",
		icon: "medal",
	},
	{
		title: "QLD XR Hub Member",
		icon: "nodes",
	},
];

const homepageTitle =
	"Matthew Aisthorpe | Technical Delivery Leader in AI, XR & Digital Platforms";
const homepageDescription =
	"Matthew Aisthorpe is a Brisbane-based technical delivery leader working across AI-enabled platforms, XR experiences, solution architecture, software delivery, and digital transformation.";
const homepageUrl = "https://matthewaisthorpe.com.au/";
const homepageImage = "https://matthewaisthorpe.com.au/assets/portrait.jpg";
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Matthew Aisthorpe",
	url: homepageUrl,
	image: homepageImage,
	jobTitle: "Technical Delivery Leader",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Brisbane",
		addressRegion: "Queensland",
		addressCountry: "Australia",
	},
	sameAs: [
		"https://www.linkedin.com/in/matthewaisthorpe/",
		"https://github.com/beardydevadventures",
		"https://www.youtube.com/@beardydevadventures",
	],
	knowsAbout: [
		"Technical Delivery",
		"Solution Architecture",
		"AI-enabled platforms",
		"XR",
		"Spatial Computing",
		"Software Delivery",
		"Digital Transformation",
		"Agile Delivery",
		"Product Delivery",
	],
};
const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "Matthew Aisthorpe",
	url: homepageUrl,
	author: {
		"@type": "Person",
		name: "Matthew Aisthorpe",
		url: homepageUrl,
	},
	publisher: {
		"@type": "Person",
		name: "Matthew Aisthorpe",
		url: homepageUrl,
	},
};

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<BaseLayout
	title={homepageTitle}
	description={homepageDescription}
	url={homepageUrl}
	image={homepageImage}
	type="website"
	schema={[personSchema, websiteSchema]}
>
	<div class="stack gap-14 lg:gap-28">
		<div class="wrapper stack gap-8 lg:gap-16">
			<header class="hero">
				<Hero
					title="Matthew Aisthorpe"
					subheading="Technical Delivery Leader across AI, XR and Digital Platforms"
					tagline="I lead cross-functional teams delivering AI-enabled platforms, immersive XR experiences, and modern digital systems from strategy through production."
					align="start"
				>
					<div class="roles">
						<Pill
							><Icon icon="target" size="1.33em" />Delivery
							Leadership</Pill
						>
						<Pill
							><Icon icon="tree-structure" size="1.33em" />Solution
							Architecture</Pill
						>
						<Pill
							><Icon icon="sparkle" size="1.33em" />AI, XR &
							Software Delivery</Pill
						>
					</div>
				</Hero>

				<img
					alt="Matthew Aisthorpe"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<section class="delivery-section stack gap-8 centered">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>How I Lead Technical Delivery</h2>
					<p>Practical delivery leadership across solution design, team execution, governance, and production-ready digital products.</p>
				</header>
				<Skills />
			</section>

			<section class="section with-cta !gap-0">
				<div class="surface card-block stack gap-4 lg:gap-6">
					<header class="stack gap-2 lg:gap-4">
						<h2>Professional Career</h2>
						<p>Want a deeper look at my work across technical leadership, digital transformation, AI, XR, and delivery governance?</p>
					</header>

					<div class="cta career-cta mt-2 lg:mt-0">
						<CallToAction
							href="https://www.linkedin.com/in/matthewaisthorpe/"
						>
							View My LinkedIn
							<Icon icon="arrow-right" size="1.1em" />
						</CallToAction>
					</div>
				</div>
			</section>
		</div>

		<main class="wrapper stack gap-16 lg:gap-24">
			<section class="section with-background with-cta centered">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Blog Posts</h2>
					<p>
						Check out my most recent blog posts, where I share
						insights, experiences, and ideas.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							posts.map((post) => (
								<li>
									<PostPreview post={post} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/blog/">
						View Blog
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background with-cta centered">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Selected Technical Projects</h2>
					<p>
						A selection of projects showcasing delivery across AI,
						XR, and modern web systems.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/projects/">
						View All Projects
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background compact">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Creative Brands</h2>
					<p>
						Creative brands where I explore immersive technology, product ideas, and hands-on software delivery.
					</p>
				</header>

				<div class="gallery creative-brands">
					<Grid variant="offset">
						<li>
							<img
								src="/assets/fovr-logo.png"
								alt="FoVR Interactive logo"
								class="h-24 object-contain mb-6 mx-auto"
							/>
							<h3 class="text-2xl font-semibold mb-2">
								FoVR Interactive
							</h3>
							<p class="text-gray-400 mb-6">
								My experimental playground for immersive
								experiences in VR, XR, and spatial computing.
								Projects like
								<em>Forge of Elements</em> and <em
									>Smash Room</em
								> explore new ways we interact, play, and build in
								virtual spaces.
							</p>
							<CallToAction href="https://fovrinteractive.net/">
								Visit FoVR Interactive
								<Icon icon="arrow-right" size="1.1em" />
							</CallToAction>
						</li>

						<li>
							<img
								src="/assets/beardydev-logo.jpg"
								alt="Beardy Dev Adventures logo"
								class="w-24 h-24 object-cover rounded-full mb-6 mx-auto"
							/>
							<h3 class="text-2xl font-semibold mb-2">
								Beardy Dev Adventures
							</h3>
							<p class="text-gray-400 mb-6">
								A devlog and YouTube series where I share dev
								experiments, immersive gameplay, and lessons
								from my experience working in the digital
								industry.
							</p>
							<CallToAction
								href="https://www.youtube.com/@beardydevadventures"
							>
								Explore Beardy Dev Adventures
								<Icon icon="arrow-right" size="1.1em" />
							</CallToAction>
						</li>
					</Grid>
				</div>
			</section>

			<section class="section with-background compact">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Recognition, Programs & Platforms</h2>
					<p>
						Selected programs, releases, and recognition across
						immersive technology, software delivery, and digital
						innovation.
					</p>
				</header>

				<div class="gallery recognition-gallery">
					<Grid variant="small">
						{
							recognitions.map((item) => (
								<li class="mention-card">
									<span class="mention-icon" aria-hidden="true">
										<Icon icon={item.icon} size="1.55rem" />
									</span>
									<p>{item.title}</p>
								</li>
							))
						}
					</Grid>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2.5rem;
		padding: 1.25rem;
		border: 1px solid color-mix(in srgb, var(--gray-800), transparent 18%);
		border-radius: 1.5rem;
		background: var(--surface-panel-strong);
		box-shadow: var(--shadow-premium);
		overflow: hidden;
	}

	.hero::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				circle at 18% 14%,
				var(--surface-glow-primary),
				transparent 36%
			),
			radial-gradient(
				circle at 86% 18%,
				var(--surface-glow-accent),
				transparent 34%
			);
		opacity: 0.9;
		pointer-events: none;
	}

	.hero > :global(.hero),
	.hero img {
		position: relative;
		z-index: 1;
	}

	.roles {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.65rem;
		margin-top: 0.75rem;
	}

	.hero img {
		width: min(100%, 28rem);
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.25rem;
		border: 1px solid var(--brand-border);
		box-shadow: 0 28px 70px rgba(9, 11, 17, 0.18);
		filter: saturate(1.04) contrast(1.03);
	}

	.section-header {
		font-size: var(--text-xl);
		text-align: center;
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: minmax(0, 1.08fr) minmax(18rem, 0.82fr);
			padding: clamp(2rem, 4vw, 3.5rem);
			gap: clamp(2.5rem, 6vw, 5rem);
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 2rem;
			object-fit: cover;
			justify-self: end;
		}

		h2 {
			font-size: var(--text-3xl);
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2.5rem;
		position: relative;
	}

	.section.centered .section-header {
		justify-self: center;
		text-align: center;
	}

	.delivery-section .section-header {
		align-items: center;
		margin-inline: auto;
		text-align: center;
	}

	.section.compact {
		gap: 1.25rem;
	}

	.section.with-cta {
		display: block;
	}

	.surface {
		position: relative;
		background: var(--surface-panel);
		border: 1px solid color-mix(in srgb, var(--gray-800), transparent 18%);
		border-radius: 1.25rem;
		padding: 1.5rem;
		box-shadow: var(--shadow-premium);
		overflow: hidden;
	}

	.surface::before {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: radial-gradient(
			circle at 94% 20%,
			var(--surface-glow-accent),
			transparent 28%
		);
	}

	.card-block {
		max-width: 100%;
		margin-inline: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.cta {
		display: flex;
		justify-content: center;
	}

	.career-cta {
		margin-left: auto;
	}

	.career-cta :global(a) {
		padding: 0.65rem 1.25rem;
		gap: 0.5rem;
		font-size: var(--text-md);
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		content: "";
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		height: clamp(18rem, 42vw, 34rem);
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			radial-gradient(
				circle at 50% 45%,
				var(--surface-glow-primary),
				transparent 46%
			),
			radial-gradient(
				circle at 74% 30%,
				var(--surface-glow-accent),
				transparent 38%
			);
		z-index: -2;
		opacity: 0.55;
	}

	.with-background.bg-variant::before {
		background:
			radial-gradient(
				circle at 46% 38%,
				var(--surface-glow-primary),
				transparent 46%
			),
			radial-gradient(
				circle at 20% 42%,
				var(--surface-glow-accent),
				transparent 38%
			);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 70ch;
		font-size: var(--text-md);
		color: var(--gray-300);
		text-wrap: pretty;
	}

	.creative-brands p {
		max-width: 50ch;
	}

	.creative-brands li {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 0.75rem;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.25rem;
		background: var(--surface-panel);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		transition:
			transform var(--theme-transition),
			box-shadow var(--theme-transition),
			border-color var(--theme-transition);
	}

	.creative-brands li:hover {
		transform: translateY(-4px);
		border-color: color-mix(
			in srgb,
			var(--accent-dark),
			var(--gray-800) 58%
		);
		box-shadow: var(--shadow-premium);
	}

	.section.with-background .gallery {
		margin-top: 2rem;
		margin-bottom: 2rem;
	}

	.section.compact .section-header {
		gap: 0.5rem;
	}

	.section.compact .gallery {
		margin-top: 1rem;
		margin-bottom: 1rem;
	}

	.recognition-gallery :global(.grid.small) {
		width: 100%;
		grid-template-columns: minmax(0, 1fr);
		gap: 1rem;
	}

	.recognition-gallery :global(.grid.small > :last-child:nth-child(odd)) {
		grid-column: auto;
	}

	.section-header h3,
	.section-header h2 {
		font-size: var(--text-2xl);
		text-wrap: balance;
	}

	.section.with-cta .section-header h2 {
		font-size: var(--text-2xl);
	}

	.card-block header h2 {
		font-size: var(--text-xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: "header header header header" "gallery gallery gallery gallery";
			gap: 4.5rem;
		}

		.section.with-cta {
			grid-template-areas: "header header header cta" "gallery gallery gallery gallery";
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.creative-brands p {
			max-width: 100%;
		}

		.section-header h3,
		.section-header h2 {
			font-size: var(--text-4xl);
		}

		.section.with-cta .section-header h2 {
			font-size: var(--text-4xl);
		}

		.card-block header h2 {
			font-size: var(--text-3xl);
		}

		.section:not(.with-cta) .section-header {
			text-align: center;
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.section.centered.with-cta .section-header {
			justify-self: center;
			text-align: center;
		}

		.card-block {
			flex-direction: row;
			align-items: center;
			column-gap: 2rem;
			padding: 2rem;
		}

		.card-block header {
			flex: 1;
		}

		.career-cta {
			justify-content: flex-end;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.mention-card {
		position: relative;
		display: flex;
		min-height: 8.25rem;
		justify-content: center;
		align-items: flex-start;
		flex-direction: column;
		gap: 0.85rem;
		text-align: center;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		color: var(--gray-200);
		background: var(--surface-panel);
		box-shadow: var(--shadow-sm);
		padding: 1.1rem;
		overflow: hidden;
		transition:
			transform var(--theme-transition),
			border-color var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	.mention-card::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(
			circle at 50% 0%,
			var(--surface-glow-primary),
			transparent 42%
		);
		opacity: 0;
		transition: opacity var(--theme-transition);
	}

	.mention-card:hover {
		transform: translateY(-3px);
		border-color: color-mix(
			in srgb,
			var(--accent-dark),
			var(--gray-800) 62%
		);
		box-shadow: var(--shadow-md);
	}

	.mention-card:hover::before {
		opacity: 1;
	}

	.mention-icon {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.75rem;
		height: 2.75rem;
		margin-inline: auto;
		border-radius: 999rem;
		color: var(--brand-primary);
		background:
			radial-gradient(circle at 50% 0%, var(--brand-primary-soft), transparent 68%),
			var(--surface-menu);
		border: 1px solid var(--brand-border);
		box-shadow: var(--shadow-sm);
		transition:
			color var(--theme-transition),
			transform var(--theme-transition),
			box-shadow var(--theme-transition);
	}

	.mention-card:hover .mention-icon {
		color: var(--brand-primary-bright);
		transform: translateY(-1px);
		box-shadow: 0 12px 26px var(--brand-primary-soft);
	}

	.mention-card p {
		position: relative;
		z-index: 1;
		width: 100%;
		font-weight: 600;
		line-height: 1.35;
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			min-height: 10.5rem;
			padding: 1.35rem;
		}
	}

	.creative-brands :global(a) {
		padding: 0.65rem 1.25rem;
		gap: 0.5rem;
		font-size: var(--text-md);
		width: fit-content;
		align-self: center;
	}
</style>
