---
import type { GetStaticPaths, Page } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import PostPreview from '../../components/PostPreview.astro';
import Hero from '../../components/Hero.astro';
import Grid from '../../components/Grid.astro';

interface Props {
	page: Page<CollectionEntry<'posts'>>;
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const posts = (await getCollection('posts')).sort(
		(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
	);

	return paginate(posts, {
		pageSize: 9,
	});
};

const { page } = Astro.props as Props;
const currentPage = page.currentPage;
const totalPages = page.lastPage;
const postsOnPage = page.data as CollectionEntry<'posts'>[];
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
const pageHref = (pageNumber: number) =>
	pageNumber === 1 ? '/blog/' : `/blog/${pageNumber}/`;
---

<BaseLayout
	title="Blog | Matthew Aisthorpe on AI, XR & Technical Delivery"
	description="Articles from Matthew Aisthorpe on AI-enabled platforms, XR, technical delivery, software delivery, product leadership, and digital transformation."
	url={currentPage === 1 ? "https://matthewaisthorpe.com.au/blog/" : `https://matthewaisthorpe.com.au/blog/${currentPage}/`}
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="My Blog"
				tagline="Sharing my insights and experiences on tech, trends, and more."
			/>
			<Grid variant="offset">
				{
					postsOnPage.map((post) => (
						<li>
							<PostPreview post={post} showReadTime={true} />
						</li>
					))
				}
			</Grid>

			{
				totalPages > 1 && (
					<nav class="pagination" aria-label="Blog pages">
						<a
							class={`pagination-link ${!page.url.prev ? 'is-disabled' : ''}`}
							href={page.url.prev ?? undefined}
							aria-disabled={!page.url.prev}
						>
							Previous
						</a>
						<ul class="pagination-pages">
							{
								pageNumbers.map((pageNumber) => (
									<li>
										<a
											class={`pagination-link ${
												pageNumber === currentPage ? 'is-active' : ''
											}`}
											href={pageHref(pageNumber)}
											aria-current={pageNumber === currentPage ? 'page' : undefined}
										>
											{pageNumber}
										</a>
									</li>
								))
							}
						</ul>
						<a
							class={`pagination-link ${!page.url.next ? 'is-disabled' : ''}`}
							href={page.url.next ?? undefined}
							aria-disabled={!page.url.next}
						>
							Next
						</a>
					</nav>
				)
			}
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.pagination {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 1rem;
	}

	.pagination-pages {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.pagination-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.5rem;
		padding: 0.45rem 0.85rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		text-decoration: none;
		font-family: var(--font-brand);
		color: var(--gray-200);
		background: var(--gradient-subtle);
		transition:
			border-color var(--theme-transition),
			color var(--theme-transition),
			transform var(--theme-transition);
	}

	.pagination-link:hover,
	.pagination-link:focus-visible {
		border-color: var(--accent-regular);
		color: var(--gray-0);
		transform: translateY(-1px);
	}

	.pagination-link.is-active {
		border-color: var(--accent-regular);
		color: var(--gray-0);
	}

	.pagination-link.is-disabled {
		pointer-events: none;
		opacity: 0.45;
	}
 </style>
