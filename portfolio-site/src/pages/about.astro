---
import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import CallToAction from "../components/CallToAction.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
import Pill from "../components/Pill.astro";
---

<BaseLayout
	title="About | Matthew Aisthorpe"
	description="About Matthew Aisthorpe, a Brisbane-based technical delivery leader working across AI-enabled platforms, XR, solution architecture, software delivery, and digital transformation."
	url="https://matthewaisthorpe.com.au/about/"
>
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About Me"
				tagline="From software engineering to technical delivery leadership across AI, XR, and digital platforms."
			>
				<img
					class="hero-image"
					width="1553"
					height="873"
					src="/assets/at-work.jpg"
					alt="Matthew Aisthorpe standing in a room looking professional and welcoming."
				/>
			</Hero>

			<section class="card info-section lead-section">
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						<b>Hello, I'm Matthew.</b> I'm a technical delivery leader
						with a background in software development, product delivery,
						solution architecture, and agile leadership. I help teams
						turn complex digital, AI, and XR ideas into practical products
						that can be scoped, built, released, and supported.
					</p>
					<p>
						My work spans education, retail, commercial platforms,
						and emerging technology. I've led delivery across
						enterprise systems, staff platforms, AI enablement,
						ecommerce integrations, web applications, and immersive
						XR experiences.
					</p>
					<p>
						I'm currently Head of XR & Web Development at 3D
						Walkabout, leading delivery across immersive XR
						experiences, AI-enabled workflows, and modern web
						platforms for enterprise and commercial projects.
					</p>
				</div>
			</section>

			<div class="about-grid">
				<aside class="sidebar snapshot-sidebar">
					<section class="card snapshot-card">
						<h2>Professional Snapshot</h2>
						<div class="snapshot-copy">
							<p>
								Matthew Aisthorpe is a Brisbane-based technical
								delivery leader working across AI-enabled
								platforms, XR experiences, modern web systems,
								and digital transformation.
							</p>
							<p>
								He leads cross-functional teams from discovery
								and solution design through delivery governance,
								stakeholder engagement, and production release.
							</p>
						</div>
						<div
							class="badge-list snapshot-tags"
							aria-label="Professional focus areas"
						>
							<Pill>Technical Delivery</Pill>
							<Pill>Solution Architecture</Pill>
							<Pill>AI-enabled Platforms</Pill>
							<Pill>XR &amp; Spatial Computing</Pill>
							<Pill>Software Delivery</Pill>
						</div>
					</section>
				</aside>

				<div class="main stack gap-6">
					<section class="card info-section">
						<h2 class="section-title">Career Highlights</h2>
						<div class="content">
							<ul>
								<li>
									<b>Project Leader at CQUniversity:</b> Led enterprise
									digital transformation initiatives, including
									the migration of legacy on-premise systems to
									cloud platforms, improving operational efficiency,
									security, and service delivery across multiple
									directorates.
								</li>
								<li>
									<b>AI Taskforce Lead at CQUniversity:</b> Established
									and led the Digital Services AI Taskforce, embedding
									GenAI and automation tools into operational workflows
									to improve productivity, reporting, and decision-making
									at scale.
								</li>
								<li>
									<b>Staff Portal Transformation:</b> Delivered
									the redesign and migration of the university's
									staff portal to SharePoint Online, increasing
									staff engagement by 126% through user-centred
									design and continuous improvement practices.
								</li>
								<li>
									<b>Product Owner at EB Games:</b> Led the delivery
									of an Uber-integrated checkout and fulfilment
									platform, enabling real-time delivery tracking
									and improving customer convenience across the
									retail ecommerce experience.
								</li>
								<li>
									<b>Founder of FoVR Interactive:</b> Founded and led an XR studio delivering immersive experiences across education, innovation, and spatial computing. Selected for Meta’s Horizon Start Program and invited to Meta Connect 2025 as a Start Partner.
								</li>
							</ul>
						</div>
					</section>

					<section class="card info-section">
						<h2 class="section-title">
							Leadership &amp; Delivery Focus
						</h2>
						<div class="content">
							<ul>
								<li>
									<b>Technical Delivery Leadership:</b> Leading
									complex, multi-stream digital initiatives from
									discovery through production release, with clear
									governance, delivery cadence, and alignment to
									business outcomes.
								</li>
								<li>
									<b
										>Solution Architecture & Technical
										Direction:</b
									>
									Shaping pragmatic architectures, integrations,
									and delivery approaches that balance user needs,
									technical constraints, maintainability, and operational
									support.
								</li>
								<li>
									<b>AI & Automation Enablement:</b> Embedding practical
									AI, GenAI, and low-code automation into operational
									workflows to improve productivity, reporting,
									and decision-making at scale.
								</li>
								<li>
									<b>Product & Software Delivery:</b> Bridging product
									strategy, stakeholder priorities, and technical
									execution across full-stack platforms, integrations,
									cloud-based systems, and release planning.
								</li>
								<li>
									<b>User-Centred Design & Experience:</b> Delivering
									intuitive, accessible digital experiences through
									close collaboration with UX, stakeholders, and
									end users.
								</li>
								<li>
									<b>Stakeholder & Team Leadership:</b> Building
									trust with senior leaders and delivery teams through
									clear communication, facilitation, delivery transparency,
									and outcome-driven decision-making.
								</li>
								<li>
									<b>XR & Emerging Technology:</b> Designing and
									delivering immersive XR experiences while applying
									spatial computing and AI to practical education,
									commercial, and innovation use cases.
								</li>
							</ul>
						</div>
					</section>

					<section class="card info-section">
						<h2 class="section-title">Education</h2>
						<div class="content">
							<ul>
								<li>
									<strong>SAE Institute Australia</strong>:
									Bachelor of Creative Media, Major in
									Interactive Media
								</li>
							</ul>
						</div>
					</section>

					<section class="card info-section">
						<h2 class="section-title">Certifications</h2>
						<div class="content">
							<ul>
								<li>
									<strong
										>Professional Scrum Master I (PSM I)</strong
									>, Scrum.org
								</li>
								<li>
									<strong
										>Professional Scrum Product Owner I
										(PSPO I)</strong
									>, Scrum.org
								</li>
								<li>
									<strong
										>AgileSHIFT – Enterprise Agility</strong
									>, PeopleCert
								</li>
								<li>
									<strong>Microsoft AI Product Manager</strong
									>, Microsoft / Coursera
								</li>
								<li>
									<strong
										>Introduction to Artificial Intelligence</strong
									>, Institute of Applied Technology (IAT)
								</li>
							</ul>
						</div>
					</section>

					<section class="card info-section">
						<h2 class="section-title">
							Explore My Professional Journey
						</h2>
						<div class="content">
							<p>
								My career spans hands-on software engineering
								through to senior technical delivery leadership,
								with experience across solution architecture,
								enterprise digital transformation, product
								delivery, AI enablement, and emerging
								technologies.
							</p>
							<div class="cta-row end cta-small">
								<CallToAction
									href="https://www.linkedin.com/in/matthewaisthorpe/"
								>
									View My LinkedIn Profile
									<Icon icon="arrow-right" size="1.1em" />
								</CallToAction>
							</div>
						</div>
					</section>

					<section class="card info-section">
						<h2 class="section-title">FoVR Interactive</h2>
						<div class="content">
							<p>
								<strong>FoVR Interactive</strong> is my independent studio focused on designing and delivering XR, spatial computing, and immersive technology projects.
							</p>
							<div class="cta-row end cta-small">
								<CallToAction
									href="https://fovrinteractive.net/"
								>
									Visit FoVR Interactive
									<Icon icon="arrow-right" size="1.1em" />
								</CallToAction>
							</div>
						</div>
					</section>

					<section class="card info-section">
						<h2 class="section-title">Beardy Dev Adventures</h2>
						<div class="content">
							<p>
								<strong>Beardy Dev Adventures</strong> is my personal devlog where I explore game development, XR, and emerging technologies through videos, blogs, and hands-on experiments.
							</p>
							<div class="cta-row end cta-small">
								<CallToAction
									href="https://www.youtube.com/@beardydevadventures"
								>
									Visit the YouTube Channel
									<Icon icon="arrow-right" size="1.1em" />
								</CallToAction>
							</div>
						</div>
					</section>
				</div>

				<aside class="sidebar support-sidebar stack gap-4">
					<div class="card badge-panel">
						<h3>Current Focus</h3>
						<p class="muted mb-3">
							Where I'm currently applying my experience across delivery, AI, XR, and software platforms.
						</p>
						<div class="badge-list">
							<Pill>Spatial Computing</Pill>
							<Pill>AI-Augmented Workflows</Pill>
							<Pill>Delivery Excellence</Pill>
							<Pill>Team Coaching</Pill>
						</div>
					</div>

					<div class="card badge-panel">
						<h3>Delivery Capabilities</h3>
						<div class="badge-list">
							<Pill>Agile & Scrum</Pill>
							<Pill>Project Leadership</Pill>
							<Pill>Product Ownership</Pill>
							<Pill>Technical Strategy</Pill>
							<Pill>System Integration</Pill>
							<Pill>UX / UI Collaboration</Pill>
							<Pill>Stakeholder Engagement</Pill>
							<Pill>XR & AI Innovation</Pill>
						</div>
					</div>

					<div class="card badge-panel">
						<h3>Technologies & Platforms</h3>
						<div class="badge-list">
							<Pill>React</Pill>
							<Pill>Next.js</Pill>
							<Pill>Astro</Pill>
							<Pill>Node.js</Pill>
							<Pill>Unity</Pill>
							<Pill>Azure</Pill>
							<Pill>AWS</Pill>
							<Pill>Power Platform</Pill>
							<Pill>Microsoft Copilot Studio</Pill>
							<Pill>ChatGPT / OpenAI API</Pill>
							<Pill>GitHub</Pill>
							<Pill>GitHub Actions</Pill>
							<Pill>Azure DevOps</Pill>
							<Pill>Jira</Pill>
							<Pill>Confluence</Pill>
						</div>
					</div>

					<div class="card badge-panel">
						<h3>Languages & Formats</h3>
						<div class="badge-list">
							<Pill>JavaScript / TypeScript</Pill>
							<Pill>C#</Pill>
							<Pill>Python</Pill>
							<Pill>SQL</Pill>
							<Pill>HTML & CSS</Pill>
							<Pill>JSON / YAML</Pill>
						</div>
					</div>
				</aside>
			</div>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.about-grid {
		display: grid;
		gap: 1.5rem;
	}

	.main {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.card {
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		padding: 1.5rem;
		box-shadow: var(--shadow-sm);
	}

	.hero-image {
		display: block;
		width: min(70%, 960px);
		height: clamp(180px, 30vw, 320px);
		object-fit: cover;
		object-position: center top;
		margin: 1rem auto 0;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	.info-section {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		color: var(--gray-200);
	}

	.lead-section {
		max-width: 100%;
	}

	.section-title {
		font-size: var(--text-lg);
		color: var(--gray-0);
	}

	.content {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	.cta-row {
		display: flex;
	}

	.cta-row.start {
		justify-content: flex-start;
	}

	.cta-row.center {
		justify-content: center;
	}

	.cta-row.end {
		justify-content: flex-end;
	}

	.cta-small :global(a) {
		padding: 0.65rem 1.25rem;
		gap: 0.5rem;
		font-size: var(--text-md);
	}

	.content ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.75rem;
	}

	.content ul li {
		position: relative;
		padding: 0.25rem 0.25rem 0.25rem 1.5rem;
		line-height: 1.6;
	}

	.content ul li::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.7em;
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 999px;
		background: var(--accent-regular);
		box-shadow: 0 0 0 6px var(--accent-subtle-overlay);
	}

	.sidebar {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.snapshot-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		overflow: hidden;
		background:
			radial-gradient(
				circle at 92% 8%,
				var(--surface-glow-accent),
				transparent 32%
			),
			radial-gradient(
				circle at 8% 0%,
				var(--surface-glow-primary),
				transparent 36%
			),
			var(--surface-panel);
		border-color: color-mix(
			in srgb,
			var(--brand-primary),
			var(--brand-border) 68%
		);
		box-shadow: var(--shadow-premium);
	}

	.snapshot-card::before {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
		border-radius: inherit;
		background: linear-gradient(
			135deg,
			var(--brand-primary-soft),
			transparent 42%,
			var(--brand-accent-soft)
		);
		opacity: 0.5;
	}

	.snapshot-card > * {
		position: relative;
		z-index: 1;
	}

	.snapshot-card h2 {
		font-size: var(--text-lg);
		color: var(--gray-0);
	}

	.snapshot-copy {
		display: grid;
		gap: 0.75rem;
		color: var(--gray-200);
		font-size: var(--text-sm);
		line-height: 1.65;
	}

	.snapshot-tags {
		padding-top: 0.25rem;
	}

	.badge-panel h3 {
		font-size: var(--text-lg);
		color: var(--gray-0);
		margin-bottom: 0.5rem;
	}

	.badge-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.muted {
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.about-grid {
			grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
			grid-template-rows: auto 1fr;
			align-items: start;
		}

		.main {
			grid-column: 1;
			grid-row: 1 / span 2;
		}

		.snapshot-sidebar {
			grid-column: 2;
			grid-row: 1;
			position: sticky;
			top: 2rem;
		}

		.support-sidebar {
			grid-column: 2;
			grid-row: 2;
		}

		.card {
			padding: 1.75rem;
		}

		.section-title {
			font-size: var(--text-xl);
		}
	}
</style>
