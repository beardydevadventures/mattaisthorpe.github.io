---
import Icon from './Icon.astro';
---

<section class="box skills">
	<div class="stack gap-2 lg:gap-4">
		<Icon icon="users-three" color="var(--accent-regular)" size="2.5rem" gradient />
		<h2>Technical Delivery & Solution Leadership</h2>
		<p>Leading teams, scope, delivery governance, stakeholder alignment, and production outcomes across digital, AI, and XR projects.</p>
	</div>
	<div class="stack gap-2 lg:gap-4">
		<Icon icon="terminal-window" color="var(--accent-regular)" size="2.5rem" gradient />
		<h2>Platform & Solution Architecture</h2>
		<p>Practical architecture across software platforms, APIs, cloud services, databases, and integrated systems.</p>
	</div>
	<div class="stack gap-2 lg:gap-4">
		<Icon icon="cube-focus" color="var(--accent-regular)" size="2.5rem" gradient />
		<h2>AI, XR & Emerging Technology Delivery</h2>
		<p>Turning AI, XR, and spatial computing concepts into practical products that can be shipped, tested, and used.</p>
	</div>

</section>

<style>
	.box {
		position: relative;
		border: 1px solid var(--gray-800);
		border-radius: 1.25rem;
		padding: 1.5rem;
		background: var(--surface-panel);
		box-shadow: var(--shadow-premium);
		overflow: hidden;
	}

	.box::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(circle at 12% 0%, var(--surface-glow-primary), transparent 30%),
			radial-gradient(circle at 88% 100%, var(--surface-glow-accent), transparent 34%);
		opacity: 0.85;
	}

	.skills {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.skills > div {
		position: relative;
		z-index: 1;
		padding: 0.25rem;
	}

	.skills h2 {
		font-size: var(--text-lg);
		text-wrap: balance;
	}

	.skills p {
		color: var(--gray-400);
		text-wrap: pretty;
	}

	.skills :global(svg) {
		filter: drop-shadow(0 10px 22px rgba(198, 90, 46, 0.22));
	}

	@media (min-width: 50em) {
		.box {
			border-radius: 1.5rem;
			padding: 2.25rem;
		}

		.skills {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}

		.skills > div {
			padding: 1rem;
			border-radius: 1rem;
			transition:
				background-color var(--theme-transition),
				transform var(--theme-transition);
		}

		.skills > div:hover {
			background-color: var(--gray-999_40);
			transform: translateY(-3px);
		}

		.skills h2 {
			font-size: var(--text-2xl);
		}
	}
</style>
