---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'posts'>;
	showReadTime?: boolean;
}

const { post, showReadTime = false } = Astro.props;
const { data, slug, body } = post;
const formattedDate = new Date(data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const WORDS_PER_MINUTE = 225;
const plainText = body
	.replace(/```[\s\S]*?```/g, ' ')
	.replace(/`[^`]*`/g, ' ')
	.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
	.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
	.replace(/<[^>]*>/g, ' ')
	.replace(/[#>*_~\-]+/g, ' ');
const wordCount = plainText.trim().split(/\s+/).filter(Boolean).length;
const readingTimeMinutes = Math.max(1, Math.ceil(wordCount / WORDS_PER_MINUTE));
const readTimeLabel = `${readingTimeMinutes} min read`;
---

<a class="card" href={`/posts/${slug}`}>
	<div class="info">
		<span class="title">{data.title}</span>
		<div class="meta">
			<time class="date" datetime={new Date(data.publishDate).toISOString()}>{formattedDate}</time>
			{showReadTime && <span class="read-time">{readTimeLabel}</span>}
		</div>
	</div>
	<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
</a>

<style>
	.card {
		position: relative;
		display: grid;
		grid-template: auto 1fr / auto 1fr;
		height: 11rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 500;
		isolation: isolate;
		transition:
			border-color var(--theme-transition),
			box-shadow var(--theme-transition),
			transform var(--theme-transition);
	}

	.card::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 0;
		background:
			linear-gradient(180deg, rgba(9, 11, 17, 0.02), rgba(9, 11, 17, 0.55)),
			radial-gradient(circle at 18% 18%, rgba(35, 199, 217, 0.28), transparent 32%);
		opacity: 0.86;
		pointer-events: none;
	}

	.card:hover,
	.card:focus-visible {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--accent-dark), var(--gray-800) 58%);
		box-shadow: var(--shadow-premium);
	}

	.info {
		display: flex;
		flex-direction: column;
		grid-area: 1 / 1 / 2 / 2;
		z-index: 2;
		margin: 0.5rem;
		padding: 0.5rem 1rem;
		background: hsla(var(--gray-999-basis), 0.72);
		color: var(--gray-200);
		border: 1px solid hsla(var(--gray-999-basis), 0.5);
		border-radius: 0.75rem;
		box-shadow: 0 12px 32px rgba(9, 11, 17, 0.14);
		backdrop-filter: blur(18px);
	}

	.date {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.read-time {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.read-time::before {
		content: '|';
		margin-right: 0.4rem;
	}

	img {
		grid-area: 1 / 1 / 3 / 3;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1.01);
		transition: transform 0.45s ease;
	}

	.card:hover img,
	.card:focus-visible img {
		transform: scale(1.06);
	}

	@media (min-width: 50em) {
		.card {
			height: 22rem;
			border-radius: 1.5rem;
		}

		.info {
			border-radius: 0.9375rem;
			margin: 0.75rem;
			padding: 0.75rem 1rem;
		}
	}
</style>
