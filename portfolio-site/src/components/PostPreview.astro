---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'posts'>;
	showReadTime?: boolean;
}

const { post, showReadTime = false } = Astro.props;
const { data, slug, body } = post;
const formattedDate = new Date(data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const WORDS_PER_MINUTE = 225;
const plainText = body
	.replace(/```[\s\S]*?```/g, ' ')
	.replace(/`[^`]*`/g, ' ')
	.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
	.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
	.replace(/<[^>]*>/g, ' ')
	.replace(/[#>*_~\-]+/g, ' ');
const wordCount = plainText.trim().split(/\s+/).filter(Boolean).length;
const readingTimeMinutes = Math.max(1, Math.ceil(wordCount / WORDS_PER_MINUTE));
const readTimeLabel = `${readingTimeMinutes} min read`;
---

<a class="card" href={`/posts/${slug}`}>
	<div class="info">
		<span class="title">{data.title}</span>
		<div class="meta">
			<time class="date" datetime={new Date(data.publishDate).toISOString()}>{formattedDate}</time>
			{showReadTime && <span class="read-time">{readTimeLabel}</span>}
		</div>
	</div>
	<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
</a>

<style>
	.card {
		display: grid;
		grid-template: auto 1fr / auto 1fr;
		height: 11rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 500;
		transition: box-shadow var(--theme-transition);
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	.info {
		display: flex;
		flex-direction: column;
		grid-area: 1 / 1 / 2 / 2;
		z-index: 1;
		margin: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--gray-999);
		color: var(--gray-200);
		border-radius: 0.375rem;
	}

	.date {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.read-time {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.read-time::before {
		content: '|';
		margin-right: 0.4rem;
	}

	img {
		grid-area: 1 / 1 / 3 / 3;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (min-width: 50em) {
		.card {
			height: 22rem;
			border-radius: 1.5rem;
		}

		.info {
			border-radius: 0.9375rem;
		}
	}
</style>
