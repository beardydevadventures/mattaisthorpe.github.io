---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

interface Props {
	project: CollectionEntry<'projects'>;
}

const { data, id } = Astro.props.project;
const formattedDate = new Date(data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const awardLabels = {
	winner: 'Winner',
	finalist: 'Finalist',
} as const;
const awardIcons = {
	winner: 'trophy',
	finalist: 'medal',
} as const;
const awardLabel = data.awardStatus ? awardLabels[data.awardStatus] : undefined;
const awardIcon = data.awardStatus ? awardIcons[data.awardStatus] : undefined;
---

<a class="card" href={`/projects/${id}`}>
	<div class="info">
		<span class="title">{data.title}</span>
		<time class="date" datetime={new Date(data.publishDate).toISOString()}>{formattedDate}</time>
	</div>
	{awardLabel && awardIcon && (
		<span class:list={['award-badge', `is-${data.awardStatus}`]}>
			<Icon icon={awardIcon} size="1em" />
			{awardLabel}
		</span>
	)}
	<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
</a>

<style>
	.card {
		position: relative;
		display: grid;
		grid-template: auto 1fr / auto 1fr;
		height: 11rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 500;
		isolation: isolate;
		transition:
			border-color var(--theme-transition),
			box-shadow var(--theme-transition),
			transform var(--theme-transition);
	}

	.card::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 0;
		background:
			linear-gradient(180deg, rgba(9, 11, 17, 0.02), rgba(9, 11, 17, 0.5)),
			radial-gradient(circle at 82% 16%, rgba(240, 122, 58, 0.24), transparent 30%),
			radial-gradient(circle at 12% 0%, rgba(110, 107, 255, 0.14), transparent 28%);
		opacity: 0.9;
		pointer-events: none;
	}

	.card:hover,
	.card:focus-visible {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--accent-dark), var(--gray-800) 58%);
		box-shadow: var(--shadow-premium);
	}

	.info {
		display: flex;
		flex-direction: column;
		grid-area: 1 / 1 / 2 / 2;
		z-index: 2;
		margin: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--card-info-bg);
		color: var(--gray-200);
		border: 1px solid var(--brand-border);
		border-radius: 0.75rem;
		box-shadow: 0 12px 32px rgba(9, 11, 17, 0.14);
		backdrop-filter: blur(18px);
	}

	.date {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.award-badge {
		position: absolute;
		right: 0.75rem;
		bottom: 0.75rem;
		z-index: 2;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.42rem 0.7rem;
		border: 1px solid color-mix(in srgb, currentColor, transparent 72%);
		border-radius: 999rem;
		background: rgba(9, 11, 17, 0.72);
		color: var(--gray-0);
		box-shadow: 0 12px 28px rgba(9, 11, 17, 0.22);
		backdrop-filter: blur(16px);
		font-size: var(--text-sm);
		font-weight: 700;
		line-height: 1;
		text-transform: uppercase;
	}

	.award-badge.is-winner {
		color: #f7c948;
	}

	.award-badge.is-finalist {
		color: #9dd7ff;
	}

	img {
		grid-area: 1 / 1 / 3 / 3;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1.01);
		transition: transform 0.45s ease;
	}

	.card:hover img,
	.card:focus-visible img {
		transform: scale(1.06);
	}

	@media (min-width: 50em) {
		.card {
			height: 22rem;
			border-radius: 1.5rem;
		}

		.info {
			border-radius: 0.9375rem;
			margin: 0.75rem;
			padding: 0.75rem 1rem;
		}

		.award-badge {
			right: 1rem;
			bottom: 1rem;
		}
	}
</style>
